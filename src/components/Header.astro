---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="nav-right">
			<div class="internal-links">
				<HeaderLink href="/">首页</HeaderLink>
				<HeaderLink href="/blog">博文</HeaderLink>
				<HeaderLink href="/about">关于我</HeaderLink>
			</div>			
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		background: #f0f0f0; /* 浅金属灰 */
		/* 浮动金属条：顶部细高光 + 底部阴影 */
		box-shadow: 
			inset 0 1px 0 rgba(255, 255, 255, 0.9), /* 顶部高光 */
			0 4px 6px -1px rgba(0, 0, 0, 0.1), 
			0 2px 4px -1px rgba(0, 0, 0, 0.06); /* 底部阴影 */
		border-bottom: 1px solid #d1d1d1;
		position: sticky;
		top: 0;
		z-index: 100;
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		width: 1100px;
		max-width: calc(100% - 2em);
		margin: auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.nav-right {
		display: flex;
		align-items: center;
		gap: 1em;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.social-links,
	.social-links a {
		display: flex;
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}
</style>
