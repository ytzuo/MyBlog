---
import { Image } from 'astro:assets';

interface Props {
	icon: string | ImageMetadata | ImageMetadata[];
	alt?: string;
	size?: number;
	/** 动画循环的时长（秒），仅对图片数组（帧动画）有效 */
	duration?: number;
}

const { icon, alt = "", size = 32, duration = 1 } = Astro.props;

const isImage = typeof icon === 'object' && icon !== null && !Array.isArray(icon);
const isAnimated = Array.isArray(icon);

// 辅助函数：将 icon 转换为数组以便进行 map 操作
const iconArray = isAnimated ? (icon as ImageMetadata[]) : [];
---

<div class="smart-icon" style={`--icon-size: ${size}px;`}>
	{
		isAnimated ? (
			<smart-icon-anim class="animated-icon-wrapper" data-duration={duration}>
				{iconArray.map((img, index) => (
					<div 
						class="frame" 
						style={`--frame-index: ${index}; --frame-count: ${iconArray.length};`}
					>
						<Image 
							src={img} 
							alt={`${alt} frame ${index + 1}`}
							width={size * 2} 
							height={size * 2}
							class="icon-img"
						/>
					</div>
				))}
			</smart-icon-anim>
		) : isImage ? (
			<Image 
				src={icon as ImageMetadata} 
				alt={alt} 
				width={size * 2} 
				height={size * 2} 
				class="icon-img"
			/>
		) : (
			<span class="icon-text">{icon}</span>
		)
	}
</div>

<style>
	.smart-icon {
		width: var(--icon-size);
		height: var(--icon-size);
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: var(--icon-size);
		line-height: 1;
		position: relative;
	}

	.icon-img {
		width: 100%;
		height: 100%;
		object-fit: contain;
		display: block;
	}

	.icon-text {
		display: block;
		line-height: 1;
	}

	/* 动画样式 */
	.animated-icon-wrapper {
		width: 100%;
		height: 100%;
		position: relative;
	}

	.frame {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		opacity: 0;
		transition: opacity 0s; /* 瞬间切换，无过渡 */
	}
</style>

<script>
	class SmartIconAnim extends HTMLElement {
		intervalId: number | undefined;

		constructor() {
			super();
		}

		connectedCallback() {
			const duration = parseFloat(this.dataset.duration || '1');
			const frames = this.querySelectorAll('.frame');
			const count = frames.length;
			
			if (count === 0) return;

			const intervalTime = (duration * 800) / count;
			let current = 0;

			// 显示第一帧
			const firstFrame = frames[0] as HTMLElement;
			if (firstFrame) firstFrame.style.opacity = '1';

			this.intervalId = window.setInterval(() => {
				// 隐藏当前帧
				const currentFrame = frames[current] as HTMLElement;
				if (currentFrame) currentFrame.style.opacity = '0';
				
				// 计算下一帧
				current = (current + 1) % count;
				
				// 显示下一帧
				const nextFrame = frames[current] as HTMLElement;
				if (nextFrame) nextFrame.style.opacity = '1';
			}, intervalTime);
		}

		disconnectedCallback() {
			if (this.intervalId) {
				clearInterval(this.intervalId);
				this.intervalId = undefined;
			}
		}
	}

	if (!customElements.get('smart-icon-anim')) {
		customElements.define('smart-icon-anim', SmartIconAnim);
	}
</script>
