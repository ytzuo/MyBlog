---
import SmartIcon from './SmartIcon.astro';
import lost1 from '../assets/lost/lost1.png';
import lost2 from '../assets/lost/lost2.png';
import lost3 from '../assets/lost/lost3.png';
import lost4 from '../assets/lost/lost4.png';
import lost5 from '../assets/lost/lost5.png';

// 幽灵帧数组
const ghostFrames: ImageMetadata[] = [lost1, lost2, lost3, lost4, lost5]; 

// 如果没有提供图片的默认回退
const fallbackIcon = "👻";

interface Props {
	count?: number;
}

const { count = 5 } = Astro.props;
---

<div id="ghost-container">
	<!-- 幽灵将由客户端脚本注入以实现随机性 -->
</div>

<!-- 单个幽灵的模板，用于克隆 -->
<template id="ghost-template">
	<div class="ghost-wrapper">
		<div class="ghost-float">
			<div class="ghost-inner">
				{
					ghostFrames.length > 0 ? (
						<SmartIcon icon={ghostFrames} duration={0.8} size={48} />
					) : (
						<SmartIcon icon={fallbackIcon} size={48} />
					)
				}
			</div>
		</div>
	</div>
</template>

<script>
	const container = document.getElementById('ghost-container');
	const template = document.getElementById('ghost-template') as HTMLTemplateElement;

	if (container && template) {
		const ghostCount = 5; // 或者如果我们通过数据属性传递它，则从 props 读取
		const mainContentWidth = 1200; // 匹配 global.css 的主要宽度
		
		for (let i = 0; i < ghostCount; i++) {
			const clone = template.content.cloneNode(true) as DocumentFragment;
			const wrapper = clone.querySelector('.ghost-wrapper') as HTMLElement;
			
			if (wrapper) {
				// 随机位置逻辑
				// 我们希望避开中心列（mainContentWidth）
				const windowWidth = window.innerWidth;
				const sideWidth = (windowWidth - mainContentWidth) / 2;
				
				let randomX;
				if (windowWidth > mainContentWidth + 100) {
					// 两侧有足够的空间
					const isLeft = Math.random() > 0.5;
					if (isLeft) {
						// 左侧：0 到 sideWidth
						randomX = Math.random() * (sideWidth - 60); // -60 是幽灵的宽度
					} else {
						// 右侧：windowWidth - sideWidth 到 windowWidth
						randomX = (windowWidth - sideWidth) + Math.random() * (sideWidth - 60);
					}
				} else {
					// 屏幕太窄，随机宽度（可能会覆盖内容）
					randomX = Math.random() * (windowWidth - 60);
				}

				const randomY = Math.random() * (document.documentElement.scrollHeight - 200) + 100;
				
				// 设置初始位置
				wrapper.style.left = `${randomX}px`;
				wrapper.style.top = `${randomY}px`;
				
				// 添加漂浮动画延迟以增加多样性
				wrapper.style.animationDelay = `-${Math.random() * 5}s`;

				// 点击事件：飞走
				wrapper.addEventListener('click', () => {
					if (wrapper.classList.contains('flying')) {
						return;
					}
					
					wrapper.classList.add('flying');
					
					// 播放音效
					// const audio = new Audio('/sounds/ghost-boo.mp3');
					// audio.play();

					// 动画结束后移除
					setTimeout(() => {
						wrapper.remove();
					}, 800); // 匹配 CSS 过渡持续时间
				});

				container.appendChild(wrapper);
			}
		}
	}
</script>

<style>
	#ghost-container {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		pointer-events: none; /* 让点击穿过空白区域 */
		overflow: hidden;
		z-index: 50; /* 在普通内容之上，但在模态框/标题之下（如果需要） */
	}

	:global(.ghost-wrapper) {
		position: absolute;
		pointer-events: auto; /* 为幽灵重新启用点击 */
		cursor: pointer;
		transition: transform 1s ease-out, opacity 1s ease-out;
		/* 初始不透明度为 0 并淡入以避免突然出现 */
		opacity: 0; 
		animation-fill-mode: forwards; /* 保持最终状态 */
	}

	/* 单独的淡入动画以处理初始加载 */
	:global(.ghost-wrapper) {
		animation: appear 1s ease-out forwards;
	}

	.ghost-float {
		animation: float 3s ease-in-out infinite;
	}

	@keyframes float {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(-15px); }
	}

	@keyframes appear {
		from { opacity: 0; }
		to { opacity: 0.7; } /* 幽灵稍微透明 */
	}

	/* 飞走状态 */
	:global(.ghost-wrapper.flying) {
		pointer-events: none;
		opacity: 0; /* 这里的 opacity 变化会触发 transition */
		transform: translateY(-100px) scale(0.9); /* transform 变化也会触发 transition */
	}

	.ghost-inner {
		/* 图标的内部容器 */
		filter: drop-shadow(0 4px 6px rgba(0,0,0,0.1));
		transition: transform 0.2s;
	}

	:global(.ghost-wrapper:hover) .ghost-inner {
		transform: scale(1.1);
	}
</style>
