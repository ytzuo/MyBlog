---
interface Props {
	date: Date | string;
}

const { date } = Astro.props;
const d = new Date(date);
// 检查日期是否有效
const isValidDate = !isNaN(d.valueOf());
---

<time datetime={isValidDate ? d.toISOString() : undefined}>
	{
		isValidDate
			? d.toLocaleDateString('en-us', {
					year: 'numeric',
					month: 'short',
					day: 'numeric',
				})
			: date
	}
</time>
