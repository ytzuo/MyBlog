---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import FormattedDate from "../FormattedDate.astro";
import Tag from "../Tag.astro";
import Card from "./Card.astro";

interface Props {
    post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
---

<Card class="post-card" hoverEffect={true}>
    {
        post.data.heroImage && (
            <a href={`/blog/${post.id}/`} class="image-link">
                <Image width={200} src={post.data.heroImage} alt="" />
            </a>
        )
    }
    <div class="post-content">
        <!-- 文章标题 -->
        <h3 class="post-title">
            <a href={`/blog/${post.id}/`}>{post.data.title}</a>
        </h3>
        <!-- 文章元数据：日期 -->
        <div class="post-meta">
            <FormattedDate date={new Date(post.data.pubDate)} />
        </div>
        <!-- 文章描述 -->
        {
            post.data.description && (
                <p class="post-description">{post.data.description}</p>
            )
        }
        <!-- 标签列表 -->
        {
            post.data.tags && post.data.tags.length > 0 && (
                <div class="tag-container">
                    {post.data.tags.map((tag) => (
                        <Tag tag={tag} />
                    ))}
                </div>
            )
        }
    </div>
</Card>

<style>
    :global(.post-card) {
        display: flex;
        gap: 1.5rem;
        margin-bottom: 2rem;
        padding: 2rem;
        text-decoration: none;
        color: inherit;
    }

    /* 正方形图片容器 */
    .image-link {
        flex-shrink: 0;
        width: 160px;
        height: 160px;
        border-radius: 8px;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        /* 当图片未铺满时露出的背景色，与整体陶瓷纸张风格一致 */
        background-color: rgba(var(--gray-light, 230, 222, 210), 0.5);
    }

    :global(.post-card) img {
        width: 100%;
        height: 100%;
        /* contain：在正方形内完整显示图片，不裁剪竖向内容 */
        object-fit: contain;
        display: block;
    }

    .post-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .post-title {
        margin: 0 0 0.5rem 0;
        font-size: 1.4rem;
        line-height: 1.2;
    }

    .post-title a {
        color: rgb(var(--black));
        text-decoration: none;
        transition: color 0.2s ease;
    }

    .post-title a:hover {
        color: var(--accent);
    }

    .post-meta {
        color: rgb(var(--gray));
        font-size: 0.9rem;
        margin-bottom: 0.8rem;
    }

    .post-description {
        margin: 0 0 1rem 0;
        color: rgb(var(--gray-dark));
    }

    .tag-container {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    @media (max-width: 720px) {
        :global(.post-card) {
            flex-direction: column;
        }

        /* 移动端改为横向铺满，高度保持正方形比例 */
        .image-link {
            width: 100%;
            height: auto;
            aspect-ratio: 1 / 1;
        }

        :global(.post-card) img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }
    }
</style>
