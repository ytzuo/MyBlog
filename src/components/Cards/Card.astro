---
interface Props {
	class?: string;
	hoverEffect?: boolean;
}

const { class: className, hoverEffect = false, ...props } = Astro.props;
---

<div class:list={['card', className, { 'hover-effect': hoverEffect }]} {...props}>
	<slot />
</div>

<style>
		:global(.card) {
			background: #ffffff;
			border-radius: 12px;
			padding: 1.5rem;
			/* 磨砂陶瓷/纸张风格：增强阴影以获得更好的分离感 */
			box-shadow:
				inset 0 1px 0 rgba(255, 255, 255, 0.8),
				0 8px 18px rgba(97, 82, 51, 0.1),
				0 16px 34px rgba(97, 82, 51, 0.08),
				0 0 0 1px rgba(0, 0, 0, 0.03); /* 微妙的边框定义 */
			position: relative;
			overflow: hidden;
			transition:
				transform 0.24s ease,
				box-shadow 0.24s ease,
				border-color 0.24s ease;
		}

	/* 应用噪点纹理叠加 */
	:global(.card)::before {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-image: var(--noise-texture);
		opacity: 0.15;
		pointer-events: none;
		z-index: 1;
	}

	.card > :global(*) {
		position: relative;
		z-index: 2;
	}

		.hover-effect:hover {
			transform: translateY(-7px) scale(1.01);
			box-shadow:
				inset 0 1px 0 rgba(255, 255, 255, 0.92),
				0 18px 32px rgba(97, 82, 51, 0.16),
				0 32px 56px rgba(97, 82, 51, 0.12),
				0 0 0 1px rgba(112, 87, 23, 0.07);
		}
	</style>
