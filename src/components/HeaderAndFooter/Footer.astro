---
const today = new Date();
---

<footer>
	<!-- 动态年份显示 -->
	&copy; {today.getFullYear()} Saten. All rights reserved.
	<p>Powered by <a href="https://astro.build">Astro</a></p>
	
	<!-- ICP备案信息（已优化样式） -->
	<div class="beian-info">
		<a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener noreferrer">
			闽ICP备2026003748号-1
		</a>
		<!-- 公安备案（建议办理后取消注释） -->
		<!-- <span class="divider">|</span>
		<a href="https://beian.mps.gov.cn/" target="_blank" rel="noopener noreferrer">
			闽公网安备XXXXXXXXXXX号
		</a> -->
	</div>
	
	<div class="social-links">
		<a href="https://github.com/ytzuo" target="_blank">
			<span class="sr-only">Go to My GitHub</span>
			<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32" astro-icon="social/github">
				<path
					fill="currentColor"
					d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
				></path>
			</svg>
		</a>
	</div>
</footer>

<style>
	footer {
		padding: 2em 1em 6em 1em;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
		text-align: center;
	}
	
	/* ICP备案信息样式 */
	.beian-info {
		margin: 1em 0;
		font-size: 0.9em;
		color: rgb(var(--gray));
	}
	
	.beian-info a {
		color: rgb(var(--gray));
		text-decoration: none;
		transition: color 0.2s ease;
	}
	
	.beian-info a:hover {
		color: rgb(var(--gray-dark));
		text-decoration: underline;
	}
	
	.divider {
		margin: 0 0.5em;
		color: rgb(var(--gray));
		opacity: 0.5;
	}
	
	.social-links {
		display: flex;
		justify-content: center;
		gap: 1em;
		margin-top: 1em;
	}
	
	.social-links a {
		text-decoration: none;
		color: rgb(var(--gray));
		transition: color 0.2s ease;
	}
	
	.social-links a:hover {
		color: rgb(var(--gray-dark));
	}
</style>
