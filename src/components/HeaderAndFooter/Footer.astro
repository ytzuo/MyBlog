---
const today = new Date();
---

<footer>
	<div class="footer-shell">
		<div class="footer-meta">
			<span>&copy; {today.getFullYear()} Saten. All rights reserved.</span>
			<p>Powered by <a href="https://astro.build">Astro</a></p>
		</div>

		<div class="beian-info">
			<a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener noreferrer">
				闽ICP备2026003748号-1
			</a>
		</div>

		<div class="social-links">
			<a href="https://github.com/ytzuo" target="_blank">
				<span class="sr-only">Go to My GitHub</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="24" height="24" astro-icon="social/github">
					<path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path>
				</svg>
			</a>
		</div>
	</div>
</footer>

	<style>
		footer {
			padding: 1.1rem 1rem 1.6rem;
			color: rgb(var(--gray));
			text-align: center;
		}

		.footer-shell {
			width: min(1040px, calc(100% - 1.5rem));
			margin: 0 auto;
			padding: 0.9rem 1.25rem;
			box-sizing: border-box;
			border-radius: 18px 18px 12px 12px;
			background:
				linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(241, 236, 227, 0.92));
			border: 1px solid rgba(122, 104, 68, 0.14);
			box-shadow:
				inset 0 1px 0 rgba(255, 255, 255, 0.85),
				0 -1px 0 rgba(255, 255, 255, 0.5),
				0 8px 18px rgba(84, 70, 39, 0.08);
			display: flex;
			align-items: center;
			justify-content: space-between;
			gap: 1rem;
			position: relative;
			overflow: hidden;
		}

		.footer-shell::before {
			content: "";
			position: absolute;
			inset: 0;
			background-image: var(--noise-texture);
			opacity: 0.08;
			pointer-events: none;
		}

		.footer-shell > * {
			position: relative;
			z-index: 1;
		}

		.footer-meta {
			display: flex;
			flex-direction: column;
			align-items: flex-start;
			gap: 0.1rem;
			font-size: 0.9rem;
			text-align: left;
		}

		.footer-meta p {
			margin: 0;
			font-size: 0.85rem;
		}

		.beian-info {
			font-size: 0.84rem;
			color: rgb(var(--gray));
		}

		.beian-info a {
			color: rgb(var(--gray));
			text-decoration: none;
			transition: color 0.2s ease;
		}

		.beian-info a:hover {
			color: rgb(var(--gray-dark));
			text-decoration: underline;
		}

		.social-links {
			display: flex;
			justify-content: center;
			gap: 0.75rem;
		}

		.social-links a {
			text-decoration: none;
			color: rgb(var(--gray));
			transition:
				color 0.2s ease,
				transform 0.2s ease;
			display: inline-flex;
			align-items: center;
			justify-content: center;
			width: 2.25rem;
			height: 2.25rem;
			border-radius: 999px;
			background: rgba(255, 255, 255, 0.55);
			box-shadow:
				inset 0 1px 0 rgba(255, 255, 255, 0.85),
				0 4px 8px rgba(84, 70, 39, 0.08);
		}

		.social-links a:hover {
			color: rgb(var(--gray-dark));
			transform: translateY(-1px);
		}

		@media (max-width: 720px) {
			.footer-shell {
				flex-direction: column;
				padding: 1rem;
				text-align: center;
			}

			.footer-meta {
				align-items: center;
				text-align: center;
			}
		}
	</style>
