---
import { SITE_TITLE } from '../../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2>
			<a href="/" class="site-logo">
				<img src="/ghost-cat-code.svg" alt="Blog Logo" width="32" height="32" />
				{SITE_TITLE}
			</a>
		</h2>
		<div class="nav-right">
			<div class="internal-links">
				<HeaderLink href="/">首页</HeaderLink>
				<HeaderLink href="/blog">博文</HeaderLink>
				<HeaderLink href="/about">关于我</HeaderLink>				
			</div>			
			<div class="social-links">
					<a href="https://github.com/ytzuo" target="_blank">
						<span class="sr-only">Go to My GitHub</span>
						<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32" astro-icon="social/github">
							<path
								fill="currentColor"
								d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z">
							</path>
						</svg>
					</a>
				</div>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		background: #f0f0f0; /* 浅金属灰 */
		/* 浮动金属条：顶部细高光 + 底部阴影 */
		box-shadow: 
			inset 0 1px 0 rgba(255, 255, 255, 0.9), /* 顶部高光 */
			0 4px 6px -1px rgba(0, 0, 0, 0.1), 
			0 2px 4px -1px rgba(0, 0, 0, 0.06); /* 底部阴影 */
		border-bottom: 1px solid #d1d1d1;
		position: sticky;
		top: 0;
		z-index: 100;
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	.site-logo {
		display: flex;
		align-items: center;
		gap: 0.5em;
	}
	.site-logo img {
		display: block;
	}
	nav {
		width: 1100px;
		max-width: calc(100% - 2em);
		margin: auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.nav-right {
		display: flex;
		align-items: center;
		gap: 1em;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.social-links,
	.social-links a {
		display: flex;
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}
</style>
