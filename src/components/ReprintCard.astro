---
interface Props {
    author: string;
    url: string;
    platform?: string;
    title?: string;
}

const { author, url, platform, title } = Astro.props;
---

<aside class="reprint-card" aria-label="转载声明">
    <div class="reprint-accent-bar"></div>
    <div class="reprint-body">
        <div class="reprint-top">
            <span class="reprint-stamp">转&thinsp;载</span>
            <span class="reprint-notice"
                >本文内容转载自第三方，版权归原作者所有</span
            >
        </div>
        <div class="reprint-bottom">
            <div class="reprint-info-col">
                <div class="reprint-author-row">
                    <span class="reprint-icon" aria-hidden="true">✍️</span>
                    <span class="reprint-author-label">原文作者</span>
                    <span class="reprint-author-name">{author}</span>
                    {
                        platform && (
                            <span class="reprint-platform">
                                ·&nbsp;{platform}
                            </span>
                        )
                    }
                </div>
                {
                    title && (
                        <div class="reprint-title-row">
                            <span class="reprint-icon" aria-hidden="true">
                                📄
                            </span>
                            <span class="reprint-author-label">原文标题</span>
                            <span class="reprint-title-name">{title}</span>
                        </div>
                    )
                }
            </div>
            <a
                href={url}
                target="_blank"
                rel="noopener noreferrer"
                class="reprint-link-btn"
            >
                访问原文
                <span class="reprint-arrow" aria-hidden="true">↗</span>
            </a>
        </div>
    </div>
</aside>

<style>
    /* ── 整体容器 ── */
    .reprint-card {
        display: flex;
        align-items: stretch;
        border-radius: 12px;
        overflow: hidden;
        margin: 2.2rem 0;
        position: relative;
        background: linear-gradient(
            135deg,
            rgba(255, 252, 244, 0.97) 0%,
            rgba(245, 238, 224, 0.95) 100%
        );
        box-shadow:
            inset 0 1px 0 rgba(255, 255, 255, 0.85),
            0 6px 16px rgba(97, 82, 51, 0.09),
            0 14px 28px rgba(97, 82, 51, 0.07),
            0 0 0 1px rgba(126, 103, 64, 0.1);
        /* 使 text-indent 不影响此卡片 */
        text-indent: 0 !important;
    }

    /* 噪点纹理叠加，与 Card 组件保持一致 */
    .reprint-card::before {
        content: "";
        position: absolute;
        inset: 0;
        background-image: var(--noise-texture);
        opacity: 0.12;
        pointer-events: none;
        z-index: 0;
    }

    /* ── 左侧 accent 色竖条 ── */
    .reprint-accent-bar {
        width: 5px;
        flex-shrink: 0;
        background: linear-gradient(
            180deg,
            var(--accent) 0%,
            var(--accent-dark) 100%
        );
        position: relative;
        z-index: 1;
    }

    /* ── 主体内容区 ── */
    .reprint-body {
        flex: 1;
        padding: 1rem 1.4rem;
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        gap: 0.65rem;
    }

    /* ── 顶行：印章 + 说明文字 ── */
    .reprint-top {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .reprint-stamp {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(
            145deg,
            var(--accent) 0%,
            var(--accent-dark) 100%
        );
        color: #fff8e4;
        font-size: 0.82rem;
        font-weight: 800;
        letter-spacing: 0.18em;
        padding: 0.18rem 0.65rem;
        border-radius: 4px;
        flex-shrink: 0;
        box-shadow:
            0 2px 6px rgba(112, 87, 23, 0.28),
            inset 0 1px 0 rgba(255, 255, 255, 0.2);
        /* 轻微倾斜，像真实印章 */
        transform: rotate(-1deg);
        user-select: none;
    }

    .reprint-notice {
        font-size: 1.1rem;
        color: rgb(var(--gray));
        line-height: 1.4;
        /* 消除全局 p 的 text-indent */
        text-indent: 0;
    }

    /* ── 底行：作者信息 + 按钮 ── */
    .reprint-bottom {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .reprint-info-col {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
    }

    .reprint-author-row,
    .reprint-title-row {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 1.2rem;
        flex-wrap: wrap;
    }

    .reprint-icon {
        font-size: 1.3rem;
        line-height: 1;
        flex-shrink: 0;
    }

    .reprint-author-label {
        color: rgb(var(--gray));
        font-size: 1.05rem;
    }

    .reprint-author-name {
        color: rgb(var(--black));
        font-weight: 700;
    }

    .reprint-platform {
        color: rgb(var(--gray));
        font-size: 1.1rem;
    }

    .reprint-title-name {
        color: rgb(var(--black));
        font-weight: 600;
    }

    /* ── "访问原文" 3D 按钮，与 Tag 组件风格一致 ── */
    .reprint-link-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        background: linear-gradient(180deg, #faf8f3 0%, #ece6dc 100%);
        padding: 0.38rem 1.1rem;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 700;
        border: 1px solid rgba(126, 103, 64, 0.16);
        color: var(--accent);
        text-decoration: none;
        white-space: nowrap;
        flex-shrink: 0;
        box-shadow:
            inset 0 1px 0 rgba(255, 255, 255, 0.92),
            0 5px 0 #cdbfa8,
            0 8px 16px rgba(84, 70, 39, 0.1);
        transition:
            transform 0.12s ease,
            box-shadow 0.12s ease,
            background 0.12s ease;
        transform: translateY(0);
    }

    .reprint-link-btn:hover {
        background: linear-gradient(180deg, #fffdf8 0%, #f3ece1 100%);
        color: var(--accent);
        transform: translateY(3px) scale(0.993);
        box-shadow:
            0 2px 0 #cdbfa8,
            inset 0 2px 5px rgba(84, 70, 39, 0.08),
            inset 0 1px 0 rgba(255, 255, 255, 0.9),
            0 5px 10px rgba(84, 70, 39, 0.12);
    }

    .reprint-link-btn:active {
        transform: translateY(5px) scale(0.988);
        background: linear-gradient(180deg, #e4dbcd 0%, #d9cdb9 100%);
        box-shadow:
            0 0 0 rgba(205, 191, 168, 0),
            inset 0 5px 10px rgba(84, 70, 39, 0.2),
            inset 0 1px 1px rgba(255, 255, 255, 0.25);
    }

    .reprint-arrow {
        font-style: normal;
        transition: transform 0.15s ease;
    }

    .reprint-link-btn:hover .reprint-arrow {
        transform: translate(2px, -2px);
    }

    /* ── 深色模式 ── */
    :global(html[data-theme="dark"]) .reprint-card {
        background: linear-gradient(
            135deg,
            var(--surface-1) 0%,
            var(--surface-2) 100%
        ) !important;
        box-shadow:
            inset 0 1px 0 rgba(255, 255, 255, 0.05),
            0 8px 20px var(--surface-shadow),
            0 0 0 1px var(--surface-border) !important;
    }

    :global(html[data-theme="dark"]) .reprint-stamp {
        background: linear-gradient(145deg, var(--accent) 0%, #a8883a 100%);
        color: #1a140a;
        box-shadow:
            0 2px 6px rgba(0, 0, 0, 0.4),
            inset 0 1px 0 rgba(255, 255, 255, 0.12);
    }

    :global(html[data-theme="dark"]) .reprint-link-btn {
        background: linear-gradient(180deg, #3b3127 0%, #2a231c 100%);
        border-color: var(--surface-border);
        color: var(--accent);
        box-shadow:
            inset 0 1px 0 rgba(255, 255, 255, 0.06),
            0 5px 0 #1a1510,
            0 8px 16px rgba(0, 0, 0, 0.28);
    }

    :global(html[data-theme="dark"]) .reprint-link-btn:hover {
        background: linear-gradient(180deg, #453929 0%, #352c22 100%);
        color: var(--accent);
        box-shadow:
            0 2px 0 #1a1510,
            inset 0 2px 5px rgba(0, 0, 0, 0.25),
            inset 0 1px 0 rgba(255, 255, 255, 0.06),
            0 5px 10px rgba(0, 0, 0, 0.3);
    }

    :global(html[data-theme="dark"]) .reprint-link-btn:active {
        background: linear-gradient(180deg, #241e18 0%, #1d1812 100%);
        box-shadow:
            0 0 0 rgba(0, 0, 0, 0),
            inset 0 5px 10px rgba(0, 0, 0, 0.4),
            inset 0 1px 1px rgba(255, 255, 255, 0.04);
    }

    /* ── 移动端适配 ── */
    @media (max-width: 560px) {
        .reprint-body {
            padding: 0.85rem 1rem;
        }

        .reprint-notice {
            display: none;
        }

        .reprint-bottom {
            flex-direction: column;
            align-items: flex-start;
            gap: 0.75rem;
        }

        .reprint-link-btn {
            width: 100%;
            justify-content: center;
        }
    }
</style>
