---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import { Image } from 'astro:assets';
import aboutImage from '../assets/blog-placeholder-about.jpg';
import Tag from '../components/Tag.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
);

const latestPosts = posts.slice(0, 5);
const postCount = posts.length;
const tags = [...new Set(posts.map((post) => post.data.tags || []).flat())];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 1200px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em;
			}
			
			/* Top Section */
			.top-section {
				display: flex;
				gap: 2rem;
				margin-bottom: 4rem;
				align-items: center;
			}
			.intro-image img {
				border-radius: 50%;
				width: 150px;
				height: 150px;
				object-fit: cover;
				box-shadow: var(--box-shadow);
			}
			.intro-text h1 {
				font-size: 2.5em;
				margin-bottom: 0.5em;
			}

			/* Bottom Section */
			.bottom-section {
				display: grid;
				grid-template-columns: 300px 1fr;
				gap: 3rem;
			}

			/* Sidebar */
			.sidebar {
				display: flex;
				flex-direction: column;
				gap: 2rem;
			}
			.widget {
				background: #ffffff;
				padding: 1.5rem;
				border-radius: 12px;
				/* Frosted ceramic/paper style: Enhanced shadows for better separation */
				box-shadow: 
					0 4px 6px -1px rgba(0, 0, 0, 0.1),
					0 2px 4px -1px rgba(0, 0, 0, 0.06),
					0 0 0 1px rgba(0,0,0,0.02); /* Subtle border definition */
				position: relative;
				overflow: hidden;
			}
			/* Apply noise texture overlay */
			.widget::before {
				content: "";
				position: absolute;
				top: 0; left: 0; width: 100%; height: 100%;
				background-image: var(--noise-texture);
				opacity: 0.4;
				pointer-events: none;
				z-index: 1;
			}
			.widget > * {
				position: relative;
				z-index: 2;
			}
			.widget h3 {
				margin-top: 0;
				margin-bottom: 1rem;
				font-size: 1.2rem;
				border-bottom: 2px solid var(--accent);
				padding-bottom: 0.5rem;
				display: inline-block;
			}
			.stat-item {
				display: flex;
				justify-content: space-between;
				margin-bottom: 0.5rem;
			}
			.tag-cloud {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
			}

			/* Latest Posts */
			.latest-posts h2 {
				margin-top: 0;
				margin-bottom: 1.5rem;
			}
			.post-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.post-item {
				display: flex;
				gap: 1.5rem;
				margin-bottom: 2rem;
				padding: 2rem;
				background: #ffffff;
				border-radius: 12px;
				/* Frosted ceramic/paper style: Enhanced shadows for better separation */
				box-shadow: 
					0 4px 6px -1px rgba(0, 0, 0, 0.1),
					0 2px 4px -1px rgba(0, 0, 0, 0.06),
					0 0 0 1px rgba(0,0,0,0.02); /* Subtle border definition */
				position: relative;
				overflow: hidden;
				transition: transform 0.2s ease, box-shadow 0.2s ease;
			}
			/* Apply noise texture overlay */
			.post-item::before {
				content: "";
				position: absolute;
				top: 0; left: 0; width: 100%; height: 100%;
				background-image: var(--noise-texture);
				opacity: 0.4;
				pointer-events: none;
				z-index: 1;
			}
			.post-item > * {
				position: relative;
				z-index: 2;
			}
			.post-item:hover {
				transform: translateY(-2px);
				box-shadow: 
					0 10px 15px -3px rgba(0, 0, 0, 0.1),
					0 4px 6px -2px rgba(0, 0, 0, 0.05),
					0 0 0 1px rgba(0,0,0,0.02);
			}
			.post-item:last-child {
				border-bottom: none;
			}
			.post-item img {
				width: 200px;
				height: 120px;
				object-fit: cover;
				border-radius: 8px;
			}
			.post-content {
				flex: 1;
			}
			.post-title {
				margin: 0 0 0.5rem 0;
				font-size: 1.4rem;
			}
			.post-title a {
				color: rgb(var(--black));
				text-decoration: none;
			}
			.post-title a:hover {
				color: var(--accent);
			}
			.post-meta {
				color: rgb(var(--gray));
				font-size: 0.9rem;
				margin-bottom: 0.5rem;
			}

			@media (max-width: 720px) {
				.top-section {
					flex-direction: column;
					text-align: center;
				}
				.bottom-section {
					grid-template-columns: 1fr;
				}
				.post-item {
					flex-direction: column;
				}
				.post-item img {
					width: 100%;
					height: auto;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<!-- Top Section: Intro -->
			<section class="top-section">
				<div class="intro-image">
					<Image src={aboutImage} alt="Profile Picture" />
				</div>
				<div class="intro-text">
					<h1>你好! I'm Saten</h1>
					<p>{SITE_DESCRIPTION}</p>
					<p>欢迎来到我的小基地。这里记录了我的学习历程、技术分享以及生活点滴。</p>
				</div>
			</section>

			<!-- Bottom Section: Split View -->
			<section class="bottom-section">
				<!-- Left Sidebar -->
				<aside class="sidebar">
					<div class="widget">
						<h3>统计信息</h3>
						<div class="stat-item">
							<span>文章总数</span>
							<strong>{postCount}</strong>
						</div>
					</div>
					
					<div class="widget">
						<h3>标签</h3>
						<div class="tag-cloud">
							{tags.length > 0 ? (
								tags.map((tag) => (
									<Tag tag={tag} />
								))
							) : (
								<p style="color: #666; font-size: 0.9em; font-style: italic;">暂无标签</p>
							)}
						</div>
					</div>
				</aside>

				<!-- Right Content: Latest Posts -->
				<div class="latest-posts">
					<ul class="post-list">
						{latestPosts.map((post) => (
							<li class="post-item">
								{post.data.heroImage && (
									<a href={`/blog/${post.id}/`}>
										<Image width={200} height={120} src={post.data.heroImage} alt="" />
									</a>
								)}
								<div class="post-content">
									<h3 class="post-title">
										<a href={`/blog/${post.id}/`}>{post.data.title}</a>
									</h3>
									<div class="post-meta">
										<FormattedDate date={post.data.pubDate} />
									</div>
									<p>{post.data.description}</p>
								</div>
							</li>
						))}
					</ul>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
