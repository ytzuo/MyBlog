---
import BaseHead from '../components/HeaderAndFooter/BaseHead.astro';
import Header from '../components/HeaderAndFooter/Header.astro';
import Footer from '../components/HeaderAndFooter/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import aboutImage from '../assets/blog-placeholder-about.jpg';
import Tag from '../components/Tag.astro';
import Card from '../components/Cards/Card.astro';
import PostCard from '../components/Cards/PostCard.astro';
import GhostSprites from '../components/GhostSprites.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
);

const latestPosts = posts.slice(0, 5);
const postCount = posts.length;
const tags = [...new Set(posts.map((post) => post.data.tags || []).flat())];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.site-wrapper {
				display: flex;
				flex-direction: column;
				min-height: 100vh;
			}

			main {
				width: 1100px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em;
				flex: 1;
			}
			
			/* Top Section */
			.top-section {
				display: flex;
				gap: 2rem;
				margin-bottom: 4rem;
				align-items: center;
			}
			.intro-image img {
				border-radius: 50%;
				width: 150px;
				height: 150px;
				object-fit: cover;
				box-shadow: var(--box-shadow);

				/* 添加过渡和变换原点 */
    			transition: transform 0.3s ease;
    			transform-origin: center bottom; /* 从底部中心摇摆，更像不倒翁 */
			}
			/* 悬浮时的摇晃动画 */
			.intro-image img:hover,
			.intro-image img.animate-shake {
    			animation: shake 0.5s ease-in-out;
			}		
			/* 关键帧定义：左右摇晃 */
			@keyframes shake {
    			0%, 100% { transform: rotate(0deg); }
    			20% { transform: rotate(-10deg); }
    			40% { transform: rotate(10deg); }
    			60% { transform: rotate(-6deg); }
    			80% { transform: rotate(6deg); }
			}
			.intro-text h1 {
				font-size: 2.5em;
				margin-bottom: 0.5em;
			}

			/* Bottom Section */
			.bottom-section {
				display: grid;
				grid-template-columns: 300px 1fr;
				gap: 3rem;
			}

			/* Sidebar */
			.sidebar {
				display: flex;
				flex-direction: column;
				gap: 2rem;
			}
			
			/* .widget 的内边距由 Card 组件默认处理 */
			:global(.widget) h3 {
				margin-top: 0;
				margin-bottom: 1rem;
				font-size: 1.2rem;
				border-bottom: 2px solid var(--accent);
				padding-bottom: 0.5rem;
				display: inline-block;
			}
			.stat-item {
				display: flex;
				justify-content: space-between;
				margin-bottom: 0.5rem;
			}
			.tag-cloud {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
			}

			/* Latest Posts */
			.latest-posts h2 {
				margin-top: 0;
				margin-bottom: 1.5rem;
			}
			.post-list {
				display: flex;
				flex-direction: column;
			}

			@media (max-width: 720px) {
				.top-section {
					flex-direction: column;
					text-align: center;
				}
				.bottom-section {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<div class="site-wrapper">
			<Header />
			<main>
				<section class="top-section">
					<div class="intro-image">
						<Image src={aboutImage} alt="Profile" />
					</div>
					<div class="intro-text">
						<h1>Hi, 我是 Saten! 👋</h1>
						<p>欢迎来到我的小基地。这里记录了我的技术探索、生活感悟以及一些奇思妙想。</p>
					</div>
				</section>

				<div class="bottom-section">
					<!-- Sidebar -->
					<aside class="sidebar">
						<Card class="widget">
							<h3>站点统计</h3>
							<div class="stat-item">
								<span>文章总数</span>
								<strong>{postCount}</strong>
							</div>
							<div class="stat-item">
								<span>标签数量</span>
								<strong>{tags.length}</strong>
							</div>
						</Card>

						<Card class="widget">
							<h3>热门标签</h3>
							<div class="tag-cloud">
								{tags.map((tag) => (
									<Tag tag={tag} />
								))}
							</div>
						</Card>
					</aside>

					<!-- Latest Posts -->
					<section class="latest-posts">
						<h2 class="section-title">最新博文</h2>
						<div class="post-list">
							{latestPosts.map((post) => (
								<PostCard post={post} />
							))}
						</div>
						<div class="view-all">
							<a href="/blog">查看全部博文 &rarr;</a>
						</div>
					</section>
				</div>
				<GhostSprites />
			</main>
			<Footer />
		</div>

		<script>
			function triggerShake() {
				const img = document.querySelector('.intro-image img');
				if (img) {
					// 添加类名触发动画
					img.classList.add('animate-shake');
					// 动画结束后移除类名，以便下次 hover 能正常触发
					setTimeout(() => {
						img.classList.remove('animate-shake');
					}, 500); // 500ms 与 CSS 动画时长一致
				}
			}

			// 监听 Astro 视图过渡后的页面加载
			document.addEventListener('astro:page-load', triggerShake);
		</script>
	</body>
</html>