---
import htmlIcon from '../assets/html.png';
import cssIcon from '../assets/css.png';
import jsIcon from '../assets/JavaScript.png';
import tsIcon from '../assets/TypeScript.png';
import reactIcon from '../assets/React.png';
import vueIcon from '../assets/Vue.png';
import astroIcon from '../assets/Astro.png';
import javaIcon from '../assets/Java.png';
import kotlinIcon from '../assets/kotlin.png';
import springBootIcon from '../assets/SpringBoot.png';
import nodeIcon from '../assets/Nodejs.png';
import pythonIcon from '../assets/Python.png';
import cppIcon from '../assets/cplusplus.png';
import cSharpIcon from '../assets/csharp.png';
import Layout from '../layouts/BlogPost.astro';
import TechCard from '../components/TechCard.astro';

const interests = [
	{
		category: "前端技术",
		items: [
			{ name: "HTML", icon: htmlIcon },
			{ name: "CSS", icon: cssIcon },
			{ name: "JavaScript", icon: jsIcon },
			{ name: "TypeScript", icon: tsIcon },
			{ name: "React", icon: reactIcon },
			{ name: "Vue", icon: vueIcon },
			{ name: "Astro", icon: astroIcon },
		]
	},
	{
		category: "后端技术",
		items: [
			{ name:"Java",icon: javaIcon },
			{ name:"kotlin",icon: kotlinIcon },
			{ name: "Python", icon: pythonIcon },
			{ name: "C/C++", icon: cppIcon },
			{ name: "C#", icon: cSharpIcon },
			{ name:"Spring Boot",icon: springBootIcon },
			{ name: "Node.js", icon: nodeIcon },
		]
	},
	{
		category: "游戏",
		items: [
			{ name: "RPG", icon: "⚔️" },
			{ name: "FPS", icon: "🔫" },
			{ name: "RougeLike", icon: "🎮" },
		]
	},
	{
		category: "其他",
		items: [
			{ name: "Music", icon: "🎵" },
			{ name: "Reading", icon: "📚" },
			{ name: "Movies", icon: "🎬" },
		]
	}
];
---

<Layout
	title="About Me"
	description="关于我自己"
	pubDate="2026-2-5 农历腊月十八"
>
	<p style="text-align: center; line-height: 1.5; margin-bottom: 2em; font-size: 1.1em;">
		软件工程大三在读，喜欢打打游戏听听歌。<br/>
		全方位探索中，如果有想分享的东西，就在这里拿出来给大家看看。
	</p>

	<hr />

	<h3 style="margin-top: 2rem; margin-bottom: 1.5rem;">本站可能包含：</h3>

	<div class="interests-grid">
		{interests.map((section) => (
			<div class="interest-section">
				<h4 class="category-title">{section.category}</h4>
				<div class="card-grid">
					{section.items.map((item) => (
						<TechCard name={item.name} icon={item.icon} />
					))}
				</div>
			</div>
		))}
	</div>

	<style>
		.interests-grid {
			display: flex;
			flex-direction: column;
			gap: 4rem;
		}

		.category-title {
			margin-bottom: 1rem;
			font-size: 1.2rem;
			color: var(--gray-dark);
			border-left: 4px solid var(--accent);
			padding-left: 0.8rem;
		}

		.card-grid {
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
			gap: 1rem;
		}

		@media (max-width: 600px) {
			.card-grid {
				grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
			}
		}
	</style>
</Layout>
